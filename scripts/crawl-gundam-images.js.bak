// ── Wikipedia REST API ────────────────────────────────────────────────────────
function fetchWikiImage(wikiTitle) {
  return new Promise((resolve) => {
    const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${wikiTitle}`;
    const opts = {
      headers: {
        'User-Agent': 'KitPickBot/1.0 (graduation-project; contact@example.com)',
        'Accept': 'application/json',
      },
      timeout: 10000,
    };
    https.get(url, opts, (res) => {
      if (res.statusCode === 301 || res.statusCode === 302) {
        // 리다이렉트 처리
        const loc = res.headers.location?.replace('https://en.wikipedia.org/api/rest_v1/page/summary/', '');
        if (loc) { fetchWikiImage(loc).then(resolve); return; }
      }
      let data = '';
      res.on('data', c => data += c);
      res.on('end', () => {
        try {
          const json = JSON.parse(data);
          // thumbnail 또는 originalimage에서 URL 추출
          const imgUrl = json.originalimage?.source || json.thumbnail?.source;
          resolve(imgUrl || null);
        } catch { resolve(null); }
      });
    }).on('error', () => resolve(null))
      .on('timeout', () => resolve(null));
  });
}

// ── 이미지 바이너리 다운로드 ─────────────────────────────────────────────────
function downloadImage(url) {
  return new Promise((resolve) => {
    const proto = url.startsWith('https') ? https : http;
    proto.get(url, {
      headers: {
        'User-Agent': 'KitPickBot/1.0',
        'Referer': 'https://en.wikipedia.org/',
      },
      timeout: 15000,
    }, (res) => {
      if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
        downloadImage(res.headers.location).then(resolve);
        return;
      }
      const chunks = [];
      res.on('data', c => chunks.push(c));
      res.on('end', () => resolve(Buffer.concat(chunks)));
    }).on('error', () => resolve(null))
      .on('timeout', () => resolve(null));
  });
}

// ── Supabase Storage 업로드 ───────────────────────────────────────────────────
async function uploadToStorage(imgBuffer, fileName, mimeType) {
  const path = `gundams/${fileName}`;
  const { error } = await supabase.storage
    .from('gundam-images')
    .upload(path, imgBuffer, { contentType: mimeType, upsert: true });

  if (error) {
    if (error.message?.includes('Bucket not found')) {
      await supabase.storage.createBucket('gundam-images', { public: true });
      const { error: e2 } = await supabase.storage
        .from('gundam-images')
        .upload(path, imgBuffer, { contentType: mimeType, upsert: true });
      if (e2) return null;
    } else {
      return null;
    }
  }

  const { data: { publicUrl } } = supabase.storage
    .from('gundam-images')
    .getPublicUrl(path);
  return publicUrl;
}

// ── 메인 ─────────────────────────────────────────────────────────────────────
async function main() {
  console.log('🔍 건담 이미지 수집 (Wikipedia API → Supabase Storage)\n');

  // 버킷 준비
  const { error: bErr } = await supabase.storage
    .createBucket('gundam-images', { public: true });
  if (!bErr || bErr.message?.includes('already exists')) {
    console.log('✅ 버킷 준비\n');
  }

  const { data: gundams } = await supabase
    .from('gundams')
    .select('id, name, image_url')
    .is('image_url', null);   // image_url 없는 것만

  if (!gundams?.length) {
    console.log('업데이트할 기체 없음 (이미 모두 이미지 있음)');
    return;
  }

  console.log(`총 ${gundams.length}개 기체 처리 시작\n`);
  let ok = 0, skip = 0, fail = 0;

  for (const g of gundams) {
    const wikiTitle = WIKI_MAP[g.name];
    if (!wikiTitle) {
      console.log(`⚠️  매핑 없음: ${g.name}`);
      skip++;
      continue;
    }

    process.stdout.write(`⏳ ${g.name} ... `);

    // 1. Wikipedia에서 이미지 URL 가져오기
    const imgUrl = await fetchWikiImage(wikiTitle);
    if (!imgUrl) {
      console.log('이미지 없음');
      fail++;
      await new Promise(r => setTimeout(r, 500));
      continue;
    }

    // 2. 이미지 다운로드
    const buf = await downloadImage(imgUrl);
    if (!buf || buf.length < 500) {
      console.log('다운로드 실패');
      fail++;
      continue;
    }

    // 3. Supabase Storage 업로드
    const ext = imgUrl.split('.').pop()?.split(/[?#]/)[0]?.toLowerCase() || 'jpg';
    const safeExt = ['jpg','jpeg','png','webp','svg'].includes(ext) ? ext : 'jpg';
    const fileName = `${g.name.replace(/[^a-zA-Z0-9가-힣]/g, '_')}.${safeExt}`;
    const mime = safeExt === 'svg' ? 'image/svg+xml' : `image/${safeExt === 'jpg' ? 'jpeg' : safeExt}`;

    const pubUrl = await uploadToStorage(buf, fileName, mime);
    if (!pubUrl) {
      console.log('업로드 실패');
      fail++;
      continue;
    }

    // 4. DB 업데이트
    const { error } = await supabase
      .from('gundams')
      .update({ image_url: pubUrl })
      .eq('id', g.id);

    if (!error) {
      console.log(`✅ (${(buf.length/1024).toFixed(0)}KB)`);
      ok++;
    } else {
      console.log(`❌ DB 오류: ${error.message}`);
      fail++;
    }

    await new Promise(r => setTimeout(r, 300)); // Wikipedia API 예의
  }

  console.log(`\n완료: ✅ ${ok}개 / ⚠️ ${skip}개 스킵 / ❌ ${fail}개 실패`);
  console.log('Supabase Storage → gundam-images 버킷에서 확인하세요.');
}

main().catch(console.error);
